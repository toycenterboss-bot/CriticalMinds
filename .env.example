# Скопируйте в .env и поменяйте значения. .env в git не попадает.
DATABASE_URL=postgresql+psycopg://optika:optika_dev_pass@localhost:5432/optika
DB_PASSWORD=optika_dev_pass

# Секрет подписи JWT — сгенерируйте свой: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Первый суперадмин (создаётся seed-скриптом при пустой БД)
SEED_ADMIN_EMAIL=andrey@optika.app
SEED_ADMIN_PASSWORD=CHANGE_ME_min_10_chars
SEED_ADMIN_NAME=Андрей

FRONTEND_ORIGIN=http://localhost:5173
